{
  "services": {
    "frontend": {
      "root": "PTHTW_FrontEnd",
      "runtime": "container"
    },
    "backend": {
      "root": "PTHTW_BackEnd",
      "runtime": "container"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/v3/api-docs/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/swagger-ui/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/swagger-ui.html",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/actuator/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}
